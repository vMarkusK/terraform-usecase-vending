{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "minimumReleaseAge": "4 days",
  "github-actions": {
    "fileMatch": [
      "^(workflow-templates|\\.github\\/workflows)\\/[^/]+\\.ya?ml$",
      "^modules\\/vending\\/files\\/workflow_.+\\.ya?ml$"
    ]
  },
  "packageRules": [
    {
      "description": "Group minor and patch updates for Terraform to reduce PR volume.",
      "matchManagers": ["terraform", "terraform-version"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Terraform Minor & Patch"
    },
    {
      "description": "Create PRs for Terraform major updates immediately after the stability period.",
      "matchManagers": ["terraform", "terraform-version"],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": false
    },
    {
      "description": "Group GitHub Actions updates and enable automerge for minor and patch versions.",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "GitHub Actions Updates",
      "automerge": true
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": false
  }
}